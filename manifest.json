{
  "manifest_version": 3,
  "name": "DeepCheck AI Floating Icon",
  "version": "1.1",
  "description": "أيقونة عائمة للفحص الفوري مع ربط السيرفر المحلي والـ APIs",
  "permissions": [
    "scripting",
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "http://localhost:5000/*",
    "https://*/*"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ],
  "action": {
    "default_title": "DeepCheck AI"
  }
}
